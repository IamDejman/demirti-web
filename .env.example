# Database (required for LMS and applications)
# IMPORTANT: Use Supabase's *transaction-mode* pooler (port 6543), not session mode (5432/5433).
# Session mode is capped at 15 clients per project and will throw
# "(EMAXCONNSESSION) max clients reached in session mode" under normal load.
# Example: postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Read replica (optional). Leave blank to reuse DATABASE_URL's pool (no extra connections).
# Only set this if you have a genuinely separate replica endpoint.
DATABASE_URL_READ_REPLICA=

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@demirti.com

# Paystack (payments)
PAYSTACK_SECRET_KEY=

# App URL (used in links, redirects)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Cron/auth (protect init-db, init-lms)
CRON_SECRET=

# Push notifications (optional)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# AI assistant (optional)
CLAUDE_API_KEY=

# Storage (optional, for uploads)
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_ENDPOINT=
STORAGE_PUBLIC_URL=

# Upstash (optional, for distributed rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
